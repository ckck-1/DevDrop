{
  "name": "devdrop-backend",
  "version": "1.0.0",
  "description": "DevDrop - AI-Powered Developer Recruitment Platform Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage --detectOpenHandles --forceExit",
    "test:watch": "jest --watch",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:unit": "jest --testPathPattern=tests/unit",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "typecheck": "npm run lint:check",
    "seed": "node scripts/seed.js",
    "worker:ai": "node workers/ai.worker.js",
    "worker:notification": "node workers/notification.worker.js",
    "docker:build": "docker build -t devdrop-backend .",
    "docker:compose": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "keywords": [
    "recruitment",
    "ai",
    "matching",
    "nodejs",
    "express",
    "mongodb",
    "redis"
  ],
  "author": "DevDrop Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "winston": "^3.10.0",
    "nodemailer": "^6.9.5",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "express-rate-limit": "^6.10.0",
    "rate-limit-redis": "^4.2.0",
    "bullmq": "^4.10.1",
    "axios": "^1.5.0",
    "stripe": "^13.5.0",
    "express-validator": "^7.0.1",
    "zod": "^3.22.2",
    "joi": "^17.9.2",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "nodemon": "^3.0.1",
    "eslint": "^8.47.0",
    "@eslint/js": "^8.47.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}